# Supabase
SUPABASE_URL=https://vkncsyhugotyfwmxpzgq.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Servidor
PORT=3001
NODE_ENV=development

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Evolution API (WhatsApp)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Segurança
API_SECRET_KEY=

# Token de alerta para rotinas automatizadas (POST /api/public/alerta-whatsapp)
# Escopo estreito: só manda WhatsApp de alerta pro número fixo no route handler,
# não dá acesso a mais nada da API — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ALERT_WEBHOOK_TOKEN=

# JWT
JWT_SECRET=

# Meta Ads
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v21.0

# Google Ads
# 1. Crie um projeto no Google Cloud Console → APIs → Google Ads API
# 2. Crie credenciais OAuth2 (tipo "Desktop app") → CLIENT_ID + CLIENT_SECRET
# 3. Obtenha o Developer Token em ads.google.com → Ferramentas → API Center
# 4. Para o REFRESH_TOKEN, rode: node scripts/get-refresh-token.js
# 5. CUSTOMER_ID: conta de anúncios (sem hífens, ex: 1234567890)
# 6. LOGIN_CUSTOMER_ID: conta MCC (só necessário se acessar via MCC)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=
